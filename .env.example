# qbo-mcp environment variables
#
# Copy to `.env` in the same directory as docker-compose.yml and fill in.
# `.env` is gitignored and .dockerignored.

# =============================================================================
# Required
# =============================================================================

# From your Intuit Developer app (Dashboard → your app → Keys & credentials).
# Use the "Production" tab keys unless you're explicitly targeting Sandbox.
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=

# The public URL Intuit will redirect to after the user authorizes. MUST
# match exactly one of the "Redirect URIs" you registered in your Intuit
# Developer app. The path must be /qbo/callback.
#
# Example: https://qbo.example.com/qbo/callback
QBO_REDIRECT_URI=

# A shared secret protecting GET /qbo/connect. Anyone with the URL +
# token can initiate an OAuth flow, so pick a long random string.
#   Generate one with:    openssl rand -hex 32
# If left blank, /qbo/connect is open — only safe for local dev behind
# a firewall.
QBO_SETUP_TOKEN=

# =============================================================================
# Optional
# =============================================================================

# "true" to use Intuit's Sandbox endpoints. Sandbox tokens don't work
# against production QuickBooks companies.
# QBO_SANDBOX=false

# Label shown in the Phase 2b OAuth AS metadata (claude.ai connector only).
# MCP_RESOURCE_NAME=QuickBooks MCP Server

# =============================================================================
# Phase 2b — OAuth AS proxy for claude.ai custom connectors (off by default)
# =============================================================================
#
# When true, the server exposes /.well-known/oauth-authorization-server,
# /.well-known/oauth-protected-resource, /authorize, /token, and validates
# bearer tokens on /mcp against an upstream authorization server
# (Auth0, Keycloak, HiveMind, etc.).
#
# MCP_AUTH_ENABLED=false
# MCP_AUTHORIZE_URL=https://your-as.example.com/authorize
# MCP_TOKEN_URL=https://your-as.example.com/token
# MCP_AUTH_ISSUER=https://your-as.example.com
# MCP_AUTH_AUDIENCE=https://qbo.example.com
# MCP_AUTH_SCOPE=qbo.access
