{
  "name": "qbo-mcp",
  "version": "0.4.7",
  "description": "QuickBooks Online MCP server for Claude Desktop — local-first, auto-OAuth, packaged as .mcpb (forked from laf-rge/quickbooks-mcp)",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "qbo-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "node dist/http-server.js",
    "dev": "tsc --watch",
    "prepare": "npm run build",
    "release": "sh scripts/release.sh"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.700.0",
    "@aws-sdk/client-ssm": "^3.700.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^17.2.3",
    "intuit-oauth": "^4.2.2",
    "jose": "^6.1.0",
    "node-quickbooks": "^2.0.47",
    "tmp": "^0.2.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/tmp": "^0.2.6",
    "typescript": "^5.3.0"
  }
}
